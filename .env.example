# ─── Guardian OpenEnv — Environment Variables ──────────────────────────────
#
# The inference script (inference.py) tries credentials in this priority order:
#
#  1. API_BASE_URL + API_KEY + MODEL_NAME  (HuggingFace router or any OpenAI-compat API)
#  2. OPENAI_API_KEY  (direct OpenAI)
#  3. No credentials → rule-based fallback agent (scores will be lower)
#
# ─── Option 1: Hugging Face Inference Router (recommended for submission) ──
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=openai/gpt-oss-120b
# API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # same value, kept as alias

# ─── Option 2: Direct OpenAI ───────────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4.1-mini

# ─── Option 3: Any OpenAI-compatible endpoint (Groq, Together, etc.) ───────
# API_BASE_URL=https://api.groq.com/openai/v1
# API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MODEL_NAME=llama-3.3-70b-versatile
