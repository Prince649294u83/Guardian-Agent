FROM node:22-bookworm-slim

ENV PNPM_HOME="/pnpm" \
    PATH="/pnpm:$PATH" \
    NODE_ENV=development \
    PORT=3000 \
    BASE_PATH=/ \
    API_BASE_URL=http://api:3001

WORKDIR /app

RUN corepack enable

COPY . .

RUN pnpm install --frozen-lockfile

EXPOSE 3000

CMD ["pnpm", "--filter", "@workspace/guardian-agent", "run", "dev"]

